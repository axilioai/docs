{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Axilio",
  "theme": "maple",
  "logo": {
    "light": "/logo/axilio-light.svg",
    "dark": "/logo/axilio-dark.svg",
    "href": "https://axilio.ai"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "dark": "#0A0A0A",
      "light": "#FFFFFF"
    }
  },
  "fonts": {
    "family": "IBM Plex Mono"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Sign up",
      "href": "https://axilio.ai"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "index",
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "icon": "cube",
            "pages": [
              "concepts/devices",
              "concepts/mobile-driver",
              "concepts/workflows-and-runs",
              "concepts/sandbox-mode"
            ]
          },
          {
            "group": "Guides",
            "icon": "book",
            "pages": [
              "guides/allocating-devices",
              "guides/controlling-devices",
              "guides/running-workflows",
              "guides/parallel-execution",
              "guides/best-practices"
            ]
          },
          {
            "group": "Platform",
            "icon": "building",
            "pages": [
              "platform/billing",
              "platform/usage",
              "platform/organizations",
              "platform/api-keys"
            ]
          },
          {
            "group": "Reference",
            "icon": "code",
            "pages": [
              "reference/errors",
              "reference/configuration",
              "reference/changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "SDK Reference",
            "icon": "code",
            "pages": [
              "api-reference/client",
              "api-reference/mobile-resource",
              "api-reference/mobile-driver",
              "api-reference/workflows-resource",
              "api-reference/runs-resource"
            ]
          },
          {
            "group": "Argus Vision API",
            "icon": "eye",
            "pages": [
              "api-reference/argus/overview",
              "api-reference/argus/infer",
              "api-reference/argus/locate",
              "api-reference/argus/models"
            ]
          },
          {
            "group": "Account & Billing API",
            "icon": "credit-card",
            "pages": [
              "api-reference/billing-resource",
              "api-reference/usage-resource",
              "api-reference/api-keys-resource",
              "api-reference/org-resource"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "href": "/reference/changelog"
      },
      {
        "tab": "GitHub ↗",
        "href": "https://github.com/axilioai/platform-python"
      },
      {
        "tab": "Dashboard ↗",
        "href": "https://axilio.ai/dashboard"
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://axilio.ai"
    }
  }
}
