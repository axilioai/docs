{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Axilio",
  "theme": "maple",
  "logo": {
    "light": "/logo/axilio-light.svg",
    "dark": "/logo/axilio-dark.svg",
    "href": "/"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "dark": "#0A0A0A",
      "light": "#FFFFFF"
    }
  },
  "fonts": {
    "family": "IBM Plex Mono"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Sign up",
      "href": "https://axilio.ai"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Platform",
        "icon": "cloud",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "index",
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Devices & Sessions",
            "icon": "mobile",
            "pages": [
              "devices/overview",
              "devices/allocate",
              "devices/discover",
              "devices/timeouts"
            ]
          },
          {
            "group": "Workflows & Runs",
            "icon": "diagram-project",
            "pages": [
              "workflows/overview",
              "workflows/create",
              "workflows/run",
              "workflows/monitor"
            ]
          },
          {
            "group": "Observability",
            "icon": "video",
            "pages": [
              "observability/overview",
              "observability/live-view",
              "observability/recordings",
              "observability/events",
              "observability/cost"
            ]
          },
          {
            "group": "Account & Billing",
            "icon": "credit-card",
            "pages": [
              {
                "group": "Billing",
                "pages": [
                  "billing/overview",
                  "billing/balance-and-invoices",
                  "billing/plans"
                ]
              },
              {
                "group": "Organization",
                "pages": [
                  "org/overview",
                  "org/members",
                  "platform/api-keys"
                ]
              }
            ]
          },
          {
            "group": "Reference",
            "icon": "circle-info",
            "pages": [
              "reference/errors",
              "reference/configuration"
            ]
          }
        ]
      },
      {
        "tab": "Drivers",
        "icon": "hand-pointer",
        "groups": [
          {
            "group": "Drivers",
            "icon": "layer-group",
            "pages": [
              "drivers/overview"
            ]
          },
          {
            "group": "Mobile driver",
            "icon": "mobile",
            "pages": [
              "driver/overview",
              {
                "group": "Basics",
                "pages": [
                  "driver/find",
                  "driver/tap",
                  "driver/type",
                  "driver/swipe",
                  "driver/buttons",
                  "driver/observe",
                  "driver/wait",
                  "driver/screenshot"
                ]
              },
              {
                "group": "Reference",
                "pages": [
                  "driver/element",
                  "driver/screen",
                  "driver/key"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "code",
        "groups": [
          {
            "group": "SDK Reference",
            "icon": "code",
            "pages": [
              "api-reference/client",
              "api-reference/mobile-resource",
              "api-reference/mobile-driver",
              "api-reference/workflows-resource",
              "api-reference/runs-resource"
            ]
          },
          {
            "group": "Argus Vision API",
            "icon": "eye",
            "pages": [
              "api-reference/argus/overview",
              "api-reference/argus/infer",
              "api-reference/argus/locate",
              "api-reference/argus/models"
            ]
          },
          {
            "group": "Account & Billing API",
            "icon": "credit-card",
            "pages": [
              "api-reference/billing-resource",
              "api-reference/usage-resource",
              "api-reference/api-keys-resource",
              "api-reference/org-resource"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "href": "/reference/changelog"
      },
      {
        "tab": "GitHub ↗",
        "href": "https://github.com/axilioai/platform-python"
      },
      {
        "tab": "Dashboard ↗",
        "href": "https://axilio.ai/dashboard"
      }
    ]
  },
  "redirects": [
    { "source": "/concepts/devices", "destination": "/devices/overview" },
    { "source": "/concepts/mobile-driver", "destination": "/driver/overview" },
    { "source": "/concepts/workflows-and-runs", "destination": "/workflows/overview" },
    { "source": "/concepts/sandbox-mode", "destination": "/workflows/overview" },
    { "source": "/workflows/sandbox-mode", "destination": "/workflows/overview" },
    { "source": "/guides/allocating-devices", "destination": "/devices/allocate" },
    { "source": "/guides/controlling-devices", "destination": "/driver/overview" },
    { "source": "/guides/running-workflows", "destination": "/workflows/create" },
    { "source": "/guides/parallel-execution", "destination": "/workflows/run" },
    { "source": "/scaling/parallel-sessions", "destination": "/workflows/run" },
    { "source": "/scaling/rate-limits", "destination": "/reference/configuration" },
    { "source": "/scaling/workflow-engine", "destination": "/workflows/overview" },
    { "source": "/guides/best-practices", "destination": "/driver/overview" },
    { "source": "/platform/billing", "destination": "/billing/overview" },
    { "source": "/platform/usage", "destination": "/observability/cost" },
    { "source": "/usage/metrics", "destination": "/observability/cost" },
    { "source": "/usage/sessions", "destination": "/observability/cost" },
    { "source": "/platform/organizations", "destination": "/org/overview" },
    { "source": "/drivers", "destination": "/drivers/overview" },
    { "source": "/driver/find-by-text", "destination": "/driver/find" },
    { "source": "/driver/find-with-vision", "destination": "/driver/find" },
    { "source": "/driver/actions", "destination": "/driver/tap" },
    { "source": "/driver/read-the-screen", "destination": "/driver/observe" },
    { "source": "/driver/hardware-keys", "destination": "/driver/buttons" },
    { "source": "/driver/waiting", "destination": "/driver/wait" },
    { "source": "/driver/screenshots", "destination": "/driver/screenshot" }
  ],
  "footer": {
    "socials": {
      "website": "https://axilio.ai"
    }
  }
}
