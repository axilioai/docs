{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Axilio",
  "theme": "maple",
  "logo": {
    "light": "/logo/axilio-light.svg",
    "dark": "/logo/axilio-dark.svg",
    "href": "/"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "dark": "#0A0A0A",
      "light": "#FFFFFF"
    }
  },
  "fonts": {
    "family": "IBM Plex Mono"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Sign up",
      "href": "https://axilio.ai"
    }
  },
