{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Axilio",
  "theme": "maple",
  "logo": {
    "light": "/logo/axilio-light.svg",
    "dark": "/logo/axilio-dark.svg",
    "href": "https://axilio.ai"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "dark": "#0A0A0A",
      "light": "#FFFFFF"
    }
  },
  "fonts": {
    "family": "IBM Plex Mono"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Sign up",
      "href": "https://axilio.ai"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "index",
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Devices",
            "icon": "mobile",
            "pages": [
              "devices/overview",
              "devices/allocate",
              "devices/discover",
              "devices/timeouts"
            ]
          },
          {
            "group": "Controlling the Device",
            "icon": "hand-pointer",
            "pages": [
              "driver/overview",
              "driver/find-by-text",
              "driver/find-with-vision",
              "driver/read-the-screen",
              "driver/actions",
              "driver/hardware-keys",
              "driver/waiting",
              "driver/screenshots"
            ]
          },
          {
            "group": "Workflows & Runs",
            "icon": "diagram-project",
            "pages": [
              "workflows/overview",
              "workflows/create",
              "workflows/run",
              "workflows/monitor",
              "workflows/sandbox-mode"
            ]
          },
          {
            "group": "Scaling",
            "icon": "bolt",
            "pages": [
              "scaling/parallel-sessions",
              "scaling/rate-limits",
              "scaling/workflow-engine"
            ]
          },
          {
            "group": "Guides",
            "icon": "book",
            "pages": [
              "guides/best-practices"
            ]
          },
          {
            "group": "Account & Billing",
            "icon": "credit-card",
            "pages": [
              "billing/overview",
              "billing/balance-and-invoices",
              "billing/plans",
              "usage/metrics",
              "usage/sessions",
              "org/overview",
              "org/members",
              "platform/api-keys"
            ]
          },
          {
            "group": "Reference",
            "icon": "code",
            "pages": [
              "reference/errors",
              "reference/configuration",
              "reference/changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "SDK Reference",
            "icon": "code",
            "pages": [
              "api-reference/client",
              "api-reference/mobile-resource",
              "api-reference/mobile-driver",
              "api-reference/workflows-resource",
              "api-reference/runs-resource"
            ]
          },
          {
            "group": "Argus Vision API",
            "icon": "eye",
            "pages": [
              "api-reference/argus/overview",
              "api-reference/argus/infer",
              "api-reference/argus/locate",
              "api-reference/argus/models"
            ]
          },
          {
            "group": "Account & Billing API",
            "icon": "credit-card",
            "pages": [
              "api-reference/billing-resource",
              "api-reference/usage-resource",
              "api-reference/api-keys-resource",
              "api-reference/org-resource"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "href": "/reference/changelog"
      },
      {
        "tab": "GitHub ↗",
        "href": "https://github.com/axilioai/platform-python"
      },
      {
        "tab": "Dashboard ↗",
        "href": "https://axilio.ai/dashboard"
      }
    ]
  },
  "redirects": [
    { "source": "/concepts/devices", "destination": "/devices/overview" },
    { "source": "/concepts/mobile-driver", "destination": "/driver/overview" },
    { "source": "/concepts/workflows-and-runs", "destination": "/workflows/overview" },
    { "source": "/concepts/sandbox-mode", "destination": "/workflows/sandbox-mode" },
    { "source": "/guides/allocating-devices", "destination": "/devices/allocate" },
    { "source": "/guides/controlling-devices", "destination": "/driver/overview" },
    { "source": "/guides/running-workflows", "destination": "/workflows/create" },
    { "source": "/guides/parallel-execution", "destination": "/scaling/parallel-sessions" },
    { "source": "/platform/billing", "destination": "/billing/overview" },
    { "source": "/platform/usage", "destination": "/usage/metrics" },
    { "source": "/platform/organizations", "destination": "/org/overview" }
  ],
  "footer": {
    "socials": {
      "website": "https://axilio.ai"
    }
  }
}
