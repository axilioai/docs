    "driver.find_all_text(contains, pattern, ocr_engine) -> list[Element]",
    "driver.find(query, timeout, ocr_engine, model) -> Element",
    "driver.wait_for_text(text, timeout, poll_ms, exact, ocr_engine) -> Element",
    "driver.wait_until_gone(text, timeout, poll_ms, exact, ocr_engine)",
    "driver.wait_for(predicate, timeout, poll_ms) -> Screen",
    "driver.tap(coords)",
    "driver.long_press(coords, duration_ms)",
    "driver.swipe(start, end, duration_ms)",
    "driver.type_text(text)",
    "driver.key_press(key)",
    "driver.screenshot() -> bytes",
    "Element.tap()",
    "Element.long_press(duration_ms)",
    "Element.type_into(text)",
    "Element.swipe_to(other, duration_ms)",
    "Screen.find_text(text, exact) -> Element | None",
    "Screen.find_all_text(contains, pattern) -> list[Element]",
    "Key.HOME / BACK / MENU / VOLUME_UP / VOLUME_DOWN / POWER ...",
    "client.workflows.list() / get() / create() / update() / delete()",
    "client.runs.list() / get() / create(workflow_id, variables) / cancel()",
    "client.billing.balance() / subscription() / invoices() / upgrade() / downgrade()",
    "client.usage.metrics(start, end, granularity) / sessions(start, end, workflow_id)",
