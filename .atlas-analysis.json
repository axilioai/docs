  "keyFeatures": [
    "Real Android phones on carrier networks for reliable mobile automation",
    "Vision-native semantic SDK — find elements by label, description, or icon appearance",
    "Parallel fleet execution with automatic load balancing and session isolation",
    "Argus vision service: YOLO icon detection, OCR (free/premium), and VLM-backed element locator",
    "Workflow scripting and scheduled runs via the dashboard and SDK",
    "Full session replay and per-step trace for production debugging",
    "Per-second billing with no data transfer fees or proxy surcharges",
    "Sandbox mode for safe workflow testing without consuming real device-minutes",
    "Organization management, API key management, and role-based access"
  ],
  "publicApiSurface": [
    "Client(api_key, base_url, timeout, max_retries, retry_base_delay)",
    "client.mobile.available(platform, location, apps)",
    "client.mobile.locations()",
    "client.mobile.supported_apps(platform, category)",
